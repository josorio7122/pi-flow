    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "private": "true",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@mariozechner/pi-tui": "^0.62.0",
    "@sinclair/typebox": "^0.34.48"
  }
