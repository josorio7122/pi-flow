{
  "name": "pi-flow",
  "version": "0.1.0",
  "description": "State-of-the-art agentic software development workflow for pi",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
